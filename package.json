{
  "name": "airmark-engine-monorepo",
  "private": true,
  "version": "0.4.4",
  "description": "Reference implementation of the AIRMark Scene Graph specification",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/engine packages/svg packages/react",
    "test": "npm run build && node --test packages/engine/test/*.test.mjs packages/react/test/*.test.mjs",
    "goldens:gen": "npm run build && node scripts/gen-goldens.mjs",
    "goldens:check": "npm run build && node scripts/run-fixtures.mjs",
    "gallery:gen": "node scripts/gen-gallery-manifest.mjs",
    "gallery:check": "node scripts/gen-gallery-manifest.mjs --check"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
