{
  "name": "airmark-engine-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Reference implementation of the AIRMark Scene Graph specification",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "tsc -b packages/engine packages/svg packages/react",
    "test": "npm run build && node --test packages/engine/test/*.test.mjs",
    "goldens:gen": "npm run build && node scripts/gen-goldens.mjs",
    "goldens:check": "npm run build && node scripts/run-fixtures.mjs"
  },
  "devDependencies": { "typescript": "^5.5.0", "@types/react": "^18.3.0" },
  "license": "MIT"
}
