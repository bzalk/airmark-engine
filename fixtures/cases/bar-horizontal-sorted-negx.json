{
  "name": "bar-horizontal-sorted-negx",
  "airspec": "1.1",
  "input": {
    "graphic": {
      "mark": {
        "type": "bar",
        "color": "#3264D6",
        "cornerRadiusEnd": 4
      },
      "encoding": {
        "x": {
          "field": "value",
          "type": "quantitative",
          "title": "Total Price (USD)",
          "axis": {
            "format": {
              "type": "currency",
              "maximumFractionDigits": 0,
              "notation": "compact"
            }
          }
        },
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": "-x",
          "title": "Category"
        }
      }
    },
    "rows": [
      {
        "category": "laptops",
        "value": 5999.95
      },
      {
        "category": "fragrances",
        "value": 419.95
      },
      {
        "category": "skincare",
        "value": 90.65
      },
      {
        "category": "groceries",
        "value": 66.95
      }
    ],
    "width": 640,
    "height": 340,
    "theme": {
      "palette": [
        "#3264D6",
        "#26A69A",
        "#F59E0B",
        "#DC5A5A"
      ],
      "hue": "#3264D6",
      "fontSize": 11,
      "axisColor": "#4A576C",
      "gridColor": "#E1E7F0",
      "labelColor": "#4A576C"
    }
  },
  "invariants": [
    "horizontal bars, longest at top",
    "y labels are category names",
    "x currency nice ticks, not data values"
  ]
}