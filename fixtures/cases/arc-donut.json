{
  "name": "arc-donut",
  "airspec": "1.1",
  "input": {
    "graphic": {
      "mark": {
        "type": "arc",
        "innerRadius": 70,
        "outerRadius": 140
      },
      "encoding": {
        "theta": {
          "field": "count",
          "type": "quantitative"
        },
        "color": {
          "field": "status",
          "type": "nominal"
        },
        "tooltip": [
          { "field": "status", "title": "Status" },
          { "field": "count", "title": "Items" },
          { "field": "share", "title": "Share", "format": { "type": "percent", "maximumFractionDigits": 0 } }
        ]
      }
    },
    "rows": [
      {
        "status": "Open",
        "count": 34,
        "share": 24
      },
      {
        "status": "Pending",
        "count": 21,
        "share": 15
      },
      {
        "status": "Closed",
        "count": 88,
        "share": 61
      }
    ],
    "width": 520,
    "height": 340,
    "theme": {
      "palette": [
        "#3264D6",
        "#26A69A",
        "#F59E0B",
        "#DC5A5A"
      ],
      "hue": "#3264D6",
      "fontSize": 11,
      "axisColor": "#4A576C",
      "gridColor": "#E1E7F0",
      "labelColor": "#4A576C"
    }
  },
  "invariants": [
    "ring slices (inner radius hole)",
    "3 slices",
    "each slice carries Status, Items, and formatted Share tooltip entries"
  ]
}
